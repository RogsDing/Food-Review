.container {
  min-height: 100vh;
  background-color: #f8f9fa;
  padding-bottom: 40rpx;
}

.profile-card {
  background: linear-gradient(135deg, #ff6b00 0%, #ff8533 100%);
  margin: 20rpx;
  border-radius: 24rpx;
  padding: 32rpx 28rpx;
  color: #fff;
}

.profile-header {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.profile-emoji {
  font-size: 48rpx;
  margin-right: 16rpx;
}

.profile-shop-name {
  font-size: 36rpx;
  font-weight: 700;
}

.profile-stats {
  display: flex;
  gap: 40rpx;
  margin-bottom: 24rpx;
}

.stat-item {
  flex: 1;
}

.stat-label {
  display: block;
  font-size: 22rpx;
  opacity: 0.85;
  margin-bottom: 4rpx;
}

.stat-rating {
  display: flex;
  align-items: baseline;
}

.stat-rating-value {
  font-size: 48rpx;
  font-weight: 700;
}

.stat-rating-unit {
  font-size: 22rpx;
  opacity: 0.7;
  margin-left: 4rpx;
}

.stat-count {
  display: block;
  font-size: 22rpx;
  opacity: 0.7;
  margin-top: 4rpx;
}

.rating-trend text {
  font-size: 24rpx;
  font-weight: 500;
}

.trend-up {
  color: #7bed9f;
}

.trend-down {
  color: #ff6b81;
}

.trend-same {
  color: rgba(255,255,255,0.8);
}

.profile-info-grid {
  display: flex;
  gap: 12rpx;
  margin-bottom: 24rpx;
}

.info-item {
  flex: 1;
  background-color: rgba(255,255,255,0.15);
  border-radius: 12rpx;
  padding: 16rpx 12rpx;
  text-align: center;
}

.info-value {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  margin-bottom: 4rpx;
}

.badge-text {
  font-size: 24rpx !important;
}

.info-label {
  display: block;
  font-size: 20rpx;
  opacity: 0.75;
}

.profile-badge {
  display: flex;
  align-items: center;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
}

.badge-icon {
  font-size: 52rpx;
  margin-right: 16rpx;
}

.badge-info {
  flex: 1;
}

.badge-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 4rpx;
}

.badge-desc {
  display: block;
  font-size: 22rpx;
  opacity: 0.85;
}

.timeline-section {
  background-color: #fff;
  margin: 20rpx;
  border-radius: 16rpx;
  overflow: hidden;
}

.timeline-header {
  padding: 24rpx 28rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.timeline-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.timeline-list {
  padding: 0 28rpx;
}

.timeline-item {
  display: flex;
  padding: 24rpx 0;
  position: relative;
}

.timeline-item:not(:last-child)::before {
  content: '';
  position: absolute;
  left: 18rpx;
  top: 50rpx;
  width: 2rpx;
  height: calc(100% - 30rpx);
  background-color: #eee;
}

.timeline-dot {
  width: 38rpx;
  height: 38rpx;
  border-radius: 50%;
  background-color: #ddd;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-right: 20rpx;
  margin-top: 4rpx;
}

.timeline-dot.latest {
  background: linear-gradient(135deg, #ff6b00 0%, #ff8533 100%);
}

.visit-count-tag {
  font-size: 18rpx;
  color: #fff;
  font-weight: 600;
}

.timeline-content {
  flex: 1;
  min-width: 0;
}

.timeline-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.timeline-rating {
  font-size: 28rpx;
  color: #ff6b00;
  font-weight: 500;
}

.timeline-time {
  font-size: 22rpx;
  color: #bbb;
}

.timeline-content-text {
  display: block;
  font-size: 28rpx;
  color: #333;
  line-height: 1.5;
  word-break: break-all;
  margin-bottom: 12rpx;
}

.timeline-images {
  display: flex;
  gap: 10rpx;
  flex-wrap: wrap;
}

.timeline-image {
  width: 140rpx;
  height: 140rpx;
  border-radius: 8rpx;
}

.timeline-empty {
  padding: 80rpx 28rpx;
  text-align: center;
  color: #ccc;
  font-size: 28rpx;
}
