.container {
  min-height: 100vh;
  background-color: #f8f9fa;
  padding-bottom: 120rpx;
}

.form-section {
  background-color: #fff;
  margin: 20rpx;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.form-item {
  margin-bottom: 24rpx;
}

.form-label {
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 12rpx;
  display: block;
  color: #333;
}

.required {
  color: #ff6b00;
  margin-left: 4rpx;
}

.form-input {
  width: 100%;
  height: 80rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  transition: all 0.3s ease;
  background-color: #fafafa;
}

.form-input:focus {
  border-color: #ff6b00;
  background-color: #fff;
  box-shadow: 0 0 0 4rpx rgba(255, 107, 0, 0.1);
}

.form-textarea {
  width: 100%;
  min-height: 200rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 12rpx;
  padding: 20rpx;
  font-size: 28rpx;
  resize: none;
  transition: all 0.3s ease;
  background-color: #fafafa;
}

.form-textarea:focus {
  border-color: #ff6b00;
  background-color: #fff;
  box-shadow: 0 0 0 4rpx rgba(255, 107, 0, 0.1);
}

.area-selector {
  display: flex;
  align-items: center;
  gap: 8rpx;
  max-width: 100%;
  width: 100%;
}

.area-selector picker {
  flex: 1;
}

.picker-input {
  width: 100%;
  box-sizing: border-box;
  height: 80rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  transition: all 0.3s ease;
  background-color: #fafafa;
  display: flex;
  align-items: center;
}

.location-btn {
  height: 80rpx;
  width: 80rpx !important; /* 修改这里：设置为 80rpx，并强制生效，使其变成一个方形小按钮 */
  min-width: 80rpx !important; /* 增加这一行：防止被微信默认按钮样式撑大 */
  padding: 0;
  background-color: #ff6b00;
  color: #fff;
  border: none;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s ease;
  flex-shrink: 0;
}

.location-btn:hover {
  background-color: #ff8533;
}

.location-btn::after {
  border: none;
}

.location-icon {
  font-size: 28rpx;
}

.rating-container {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.stars-display {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 8rpx;
  padding: 16rpx;
  background-color: #fafafa;
  border-radius: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.star-icon {
  font-size: 40rpx;
  color: #e0e0e0;
  transition: all 0.3s ease;
  text-shadow: 0 1rpx 2rpx rgba(0, 0, 0, 0.1);
}

.star-icon.active {
  color: #ffd700;
  text-shadow: 0 2rpx 4rpx rgba(255, 215, 0, 0.4);
  transform: scale(1.1);
}

.star-icon.half {
  color: #ffd700;
  text-shadow: 0 2rpx 4rpx rgba(255, 215, 0, 0.4);
  position: relative;
  transform: scale(1.1);
}

.star-icon.half::after {
  content: '★';
  position: absolute;
  top: 0;
  left: 0;
  width: 50%;
  overflow: hidden;
  color: #e0e0e0;
  text-shadow: 0 1rpx 2rpx rgba(0, 0, 0, 0.1);
}

.rating-value {
  font-size: 36rpx;
  font-weight: 700;
  color: #ff6b00;
  margin-left: 20rpx;
  padding: 8rpx 16rpx;
  background-color: #fff;
  border-radius: 20rpx;
  box-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.1);
  min-width: 80rpx;
  text-align: center;
}

.slider-container {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin: 8rpx 0;
}

.slider-label {
  font-size: 24rpx;
  color: #666;
  min-width: 60rpx;
  text-align: center;
}

.rating-slider {
  flex: 1;
  height: 8rpx;
}

.rating-slider .wx-slider-thumb {
  width: 28rpx;
  height: 28rpx;
  background-color: #ff6b00;
  border-radius: 50%;
  box-shadow: 0 2rpx 8rpx rgba(255, 107, 0, 0.3);
}

.rating-slider .wx-slider-track {
  background-color: #ff6b00;
  height: 8rpx;
  border-radius: 4rpx;
}

.rating-slider .wx-slider-background {
  background-color: #e0e0e0;
  height: 8rpx;
  border-radius: 4rpx;
}

.slider-hint {
  font-size: 20rpx;
  color: #999;
  text-align: center;
  margin-top: 4rpx;
}

.category-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 12rpx;
}

.category-tag {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  padding: 16rpx;
  background-color: #fafafa;
  border: 2rpx solid #e0e0e0;
  border-radius: 12rpx;
  transition: all 0.3s ease;
  min-width: 100rpx;
  cursor: pointer;
}

.category-tag:hover {
  border-color: #ff6b00;
  background-color: rgba(255, 107, 0, 0.05);
  transform: translateY(-2rpx);
}

.category-tag.selected {
  border-color: #ff6b00;
  background-color: rgba(255, 107, 0, 0.1);
  box-shadow: 0 2rpx 8rpx rgba(255, 107, 0, 0.2);
}

.category-icon {
  font-size: 36rpx;
}

.category-text {
  font-size: 24rpx;
  color: #333;
  text-align: center;
}

.category-hint {
  display: block;
  font-size: 24rpx;
  color: #ff6b00;
  margin-top: 12rpx;
}

.image-upload {
  display: flex;
  gap: 20rpx;
  flex-wrap: wrap;
}

.upload-item {
  width: 160rpx;
  height: 160rpx;
  border: 2rpx dashed #e0e0e0;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  color: #999;
  transition: all 0.3s ease;
  background-color: #fafafa;
}

.upload-item:hover {
  border-color: #ff6b00;
  background-color: rgba(255, 107, 0, 0.05);
  transform: translateY(-2rpx);
}

.uploaded-image {
  width: 160rpx;
  height: 160rpx;
  position: relative;
  border-radius: 12rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.1);
  transition: all 0.3s ease;
}

.uploaded-image:hover {
  transform: scale(1.02);
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.15);
}

.uploaded-image image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.delete-image {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 40rpx;
  height: 40rpx;
  background-color: rgba(0, 0, 0, 0.6);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  border-radius: 50%;
  transition: all 0.3s ease;
  cursor: pointer;
}

.delete-image:hover {
  background-color: rgba(0, 0, 0, 0.8);
  transform: scale(1.1);
}

.submit-btn {
  position: fixed;
  bottom: 80rpx;
  left: 20rpx;
  right: 20rpx;
  height: 88rpx;
  background-color: #ff6b00;
  color: #fff;
  border: none;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: 600;
  box-shadow: 0 4rpx 12rpx rgba(255, 107, 0, 0.3);
  transition: all 0.3s ease;
  display: flex;
  align-items: center;
  justify-content: center;
}

.submit-btn:hover {
  background-color: #ff8533;
  box-shadow: 0 6rpx 16rpx rgba(255, 107, 0, 0.4);
  transform: translateY(-2rpx);
}

.submit-btn::after {
  border: none;
}

/* 响应式调整 */
@media (max-width: 375px) {
  .form-section {
    margin: 16rpx;
    padding: 20rpx;
  }
  
  .form-item {
    margin-bottom: 20rpx;
  }
  
  .form-label {
    font-size: 26rpx;
  }
  
  .form-input {
    height: 72rpx;
    font-size: 26rpx;
  }
  
  .form-textarea {
    min-height: 180rpx;
    font-size: 26rpx;
  }
  
  .rating-star {
    width: 40rpx;
    height: 40rpx;
  }
  
  .upload-item,
  .uploaded-image {
    width: 140rpx;
    height: 140rpx;
  }
  
  .submit-btn {
    height: 80rpx;
    font-size: 28rpx;
  }
}

.shop-history-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.shop-history-content {
  width: 85%;
  max-width: 600rpx;
  background-color: #fff;
  border-radius: 24rpx;
  padding: 40rpx 32rpx;
  animation: shopHistoryBounce 0.3s ease;
}

@keyframes shopHistoryBounce {
  0% { transform: scale(0.8); opacity: 0; }
  100% { transform: scale(1); opacity: 1; }
}

.shop-history-header {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.shop-history-emoji {
  font-size: 44rpx;
  margin-right: 12rpx;
}

.shop-history-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #ff6b00;
}

.shop-history-last {
  background-color: #fff8f3;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 24rpx;
}

.shop-history-label {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.shop-history-info {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.shop-history-rating {
  font-size: 28rpx;
  color: #ff6b00;
  font-weight: 500;
}

.shop-history-time {
  font-size: 22rpx;
  color: #bbb;
}

.shop-history-content-preview {
  font-size: 26rpx;
  color: #666;
  line-height: 1.4;
}

.shop-history-compare {
  margin-bottom: 28rpx;
}

.shop-history-compare-title {
  display: block;
  font-size: 26rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 16rpx;
}

.shop-history-options {
  display: flex;
  gap: 16rpx;
}

.compare-option {
  flex: 1;
  padding: 16rpx 12rpx;
  border-radius: 12rpx;
  background-color: #f5f5f5;
  text-align: center;
  transition: all 0.2s ease;
  border: 2rpx solid transparent;
}

.compare-option.active {
  background-color: rgba(255, 107, 0, 0.08);
  border-color: #ff6b00;
}

.compare-icon {
  display: block;
  font-size: 36rpx;
  margin-bottom: 4rpx;
}

.compare-text {
  display: block;
  font-size: 22rpx;
  color: #666;
}

.compare-option.active .compare-text {
  color: #ff6b00;
  font-weight: 500;
}

.shop-history-actions {
  display: flex;
  gap: 16rpx;
}

.shop-history-btn {
  flex: 1;
  height: 72rpx;
  line-height: 72rpx;
  border-radius: 36rpx;
  font-size: 28rpx;
  padding: 0;
  border: none;
}

.shop-history-btn::after {
  border: none;
}

.shop-history-btn.cancel {
  background-color: #f5f5f5;
  color: #666;
}

.shop-history-btn.confirm {
  background: linear-gradient(135deg, #ff6b00 0%, #ff8533 100%);
  color: #fff;
}