.container {
  min-height: 100vh;
  background-color: #f8f9fa;
  padding-bottom: 40rpx;
}

.header {
  background: linear-gradient(135deg, #ff6b00 0%, #ff8533 100%);
  color: #fff;
  padding: 40rpx 32rpx 48rpx;
  text-align: center;
  border-radius: 0 0 32rpx 32rpx;
}

.header-title {
  font-size: 40rpx;
  font-weight: 700;
  display: block;
  margin-bottom: 8rpx;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.1);
}

.header-subtitle {
  font-size: 26rpx;
  opacity: 0.9;
  display: block;
}

.message-input-section {
  background-color: #fff;
  margin: 24rpx 20rpx;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.message-input {
  width: 100%;
  min-height: 160rpx;
  max-height: 320rpx;
  background-color: #f8f9fa;
  border-radius: 12rpx;
  padding: 24rpx;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
  border: 2rpx solid #e8e8e8;
  transition: all 0.3s ease;
}

.message-input:focus {
  border-color: #ff6b00;
  background-color: #fff;
}

.input-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 16rpx;
}

.char-count {
  font-size: 24rpx;
  color: #999;
}

.submit-btn {
  background-color: #e0e0e0;
  color: #999;
  font-size: 28rpx;
  font-weight: 600;
  padding: 12rpx 40rpx;
  border-radius: 32rpx;
  border: none;
  transition: all 0.3s ease;
}

.submit-btn.active {
  background: linear-gradient(135deg, #ff6b00 0%, #ff8533 100%);
  color: #fff;
  box-shadow: 0 4rpx 12rpx rgba(255, 107, 0, 0.3);
}

.submit-btn.active:hover {
  transform: translateY(-2rpx);
  box-shadow: 0 6rpx 16rpx rgba(255, 107, 0, 0.4);
}

.submit-btn::after {
  border: none;
}

.divider {
  height: 1rpx;
  background-color: #f0f0f0;
  margin: 0 20rpx;
}

.message-list {
  margin-top: 24rpx;
}

.list-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0 20rpx;
  margin-bottom: 16rpx;
}

.list-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.list-count {
  font-size: 24rpx;
  color: #999;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #666;
  font-weight: 500;
  margin-bottom: 12rpx;
}

.empty-hint {
  font-size: 24rpx;
  color: #999;
}

.loading-state {
  text-align: center;
  padding: 40rpx 0;
  color: #999;
  font-size: 26rpx;
}

.message-item {
  background-color: #fff;
  margin: 0 20rpx 16rpx;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.03);
}

.message-header {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.message-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  overflow: hidden;
  background-color: #f0f0f0;
  margin-right: 16rpx;
  border: 2rpx solid #f0f0f0;
}

.message-info {
  flex: 1;
}

.message-nickname {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  display: block;
  margin-bottom: 4rpx;
}

.message-time {
  font-size: 22rpx;
  color: #999;
  display: block;
}

.delete-btn {
  padding: 8rpx 20rpx;
  background-color: #f0f0f0;
  border-radius: 20rpx;
  transition: all 0.3s ease;
}

.delete-btn:active {
  background-color: #ff6b00;
}

.delete-btn:active text {
  color: #fff;
}

.delete-btn text {
  font-size: 24rpx;
  color: #999;
  transition: color 0.3s ease;
}

.message-content {
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
  word-break: break-all;
}

@media (max-width: 375px) {
  .header {
    padding: 32rpx 20rpx 40rpx;
  }

  .header-title {
    font-size: 36rpx;
  }

  .message-input-section {
    margin: 20rpx 16rpx;
    padding: 20rpx;
  }

  .message-item {
    margin: 0 16rpx 12rpx;
    padding: 20rpx;
  }

  .message-avatar {
    width: 64rpx;
    height: 64rpx;
  }

  .message-nickname {
    font-size: 26rpx;
  }

  .message-content {
    font-size: 26rpx;
  }
}