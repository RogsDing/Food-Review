.container {
  min-height: 100vh;
  background-color: #f8f9fa;
  padding-bottom: 160rpx;
}

.detail-header {
  background-color: #fff;
  padding: 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
  box-shadow: 0 1rpx 3rpx rgba(0, 0, 0, 0.05);
}

/* 发布者信息 */
.author-info {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
  gap: 12rpx;
}

.author-avatar {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.author-name {
  font-size: 24rpx;
  color: #666;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.detail-shop-name {
  font-size: 36rpx;
  font-weight: 600;
  display: block;
  margin-bottom: 16rpx;
  color: #333;
  line-height: 1.3;
}

.detail-meta {
  display: flex;
  align-items: center;
  gap: 24rpx;
  font-size: 26rpx;
  color: #666;
  margin-bottom: 16rpx;
  flex-wrap: wrap;
}

.review-rating {
  display: flex;
  align-items: center;
}

.star {
  width: 32rpx;
  height: 32rpx;
  margin-left: 8rpx;
  background-color: #e0e0e0;
  clip-path: polygon(50% 0%, 61% 35%, 98% 35%, 68% 57%, 79% 91%, 50% 70%, 21% 91%, 32% 57%, 2% 35%, 39% 35%);
  transition: all 0.3s ease;
}

.star.active {
  background-color: #ffd700;
  transform: scale(1.1);
}

.detail-content {
  background-color: #fff;
  padding: 24rpx;
  margin-top: 20rpx;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
  margin: 20rpx;
}

.detail-text {
  font-size: 28rpx;
  line-height: 1.6;
  margin-bottom: 24rpx;
  display: block;
  color: #333;
}

.detail-images {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.detail-image {
  width: calc(33.333% - 10.666rpx);
  aspect-ratio: 1;
  border-radius: 12rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.1);
  transition: all 0.3s ease;
  cursor: pointer;
}

.detail-image:hover {
  transform: scale(1.02);
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.15);
}

.detail-image image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.detail-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 24rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid #f0f0f0;
}

.action-btn {
  flex: 1;
  height: 80rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 40rpx;
  font-size: 28rpx;
  background-color: #fff;
  color: #666;
  font-weight: 500;
  transition: all 0.3s ease;
  display: flex;
  align-items: center;
  justify-content: center;
}

.action-btn:hover {
  border-color: #d0d0d0;
  background-color: #f5f5f5;
  transform: translateY(-2rpx);
}

.action-btn.primary {
  background-color: #ff6b00;
  color: #fff;
  border-color: #ff6b00;
  box-shadow: 0 2rpx 6rpx rgba(255, 107, 0, 0.3);
}

.action-btn.primary:hover {
  background-color: #ff8533;
  box-shadow: 0 3rpx 8rpx rgba(255, 107, 0, 0.4);
}

.action-btn::after {
  border: none;
}

/* 响应式调整 */
@media (max-width: 375px) {
  .detail-header {
    padding: 20rpx;
  }
  
  .detail-shop-name {
    font-size: 32rpx;
  }
  
  .detail-meta {
    font-size: 24rpx;
    gap: 20rpx;
  }
  
  .detail-content {
    padding: 20rpx;
    margin: 16rpx;
  }
  
  .detail-text {
    font-size: 26rpx;
  }
  
  .detail-image {
    width: calc(33.333% - 8rpx);
    gap: 12rpx;
  }
  
  .action-btn {
    height: 72rpx;
    font-size: 26rpx;
  }
}

.comment-section {
  background-color: #fff;
  margin: 20rpx;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
  overflow: hidden;
}

.comment-header {
  padding: 24rpx 28rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.comment-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.comment-list {
  padding: 0 28rpx;
}

.comment-item {
  display: flex;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.comment-item:last-child {
  border-bottom: none;
}

.comment-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  flex-shrink: 0;
  margin-right: 20rpx;
}

.comment-body {
  flex: 1;
  min-width: 0;
}

.comment-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.comment-nickname {
  font-size: 26rpx;
  color: #666;
  font-weight: 500;
}

.comment-delete {
  font-size: 22rpx;
  color: #999;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  transition: all 0.3s ease;
}

.comment-delete:active {
  color: #ff6b00;
  background-color: rgba(255, 107, 0, 0.05);
}

.comment-text {
  display: block;
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
  word-break: break-all;
  margin-bottom: 8rpx;
}

.comment-time {
  display: block;
  font-size: 22rpx;
  color: #bbb;
}

.comment-empty {
  padding: 60rpx 28rpx;
  text-align: center;
}

.comment-empty-text {
  font-size: 28rpx;
  color: #ccc;
}

.comment-input-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: #fff;
  padding: 16rpx 24rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  display: flex;
  align-items: center;
  gap: 16rpx;
  border-top: 1rpx solid #f0f0f0;
  box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.05);
  z-index: 100;
}

.comment-input {
  flex: 1;
  height: 72rpx;
  background-color: #f8f9fa;
  border-radius: 36rpx;
  padding: 0 28rpx;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
}

.comment-send-btn {
  width: 120rpx;
  height: 72rpx;
  line-height: 72rpx;
  background: linear-gradient(135deg, #ff6b00 0%, #ff8533 100%);
  color: #fff;
  font-size: 28rpx;
  font-weight: 500;
  border-radius: 36rpx;
  padding: 0;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s ease;
  box-shadow: 0 4rpx 12rpx rgba(255, 107, 0, 0.3);
}

.comment-send-btn::after {
  border: none;
}

.comment-send-btn[disabled] {
  background: #e0e0e0;
  color: #999;
  box-shadow: none;
}