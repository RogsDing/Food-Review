<view class="container">
  <view class="header-summary">
    <text class="summary-emoji">👣</text>
    <text class="summary-text">共探访 <text class="summary-num">{{totalShops}}</text> 家店铺，留下 <text class="summary-num">{{totalReviews}}</text> 条足迹</text>
  </view>

  <view class="map-section">
    <view class="map-header">
      <text class="map-title">📍 美食足迹</text>
      <text class="map-subtitle">已探访 {{visitedCities.length}} 座城市</text>
    </view>
    
    <view class="city-cards" wx:if="{{visitedCities.length > 0}}">
      <scroll-view scroll-x="true" class="city-scroll">
        <view class="city-card-wrap">
          <view class="city-card"
                wx:for="{{visitedCities}}"
                wx:key="index"
                bindtap="selectCity"
                data-city="{{item}}">
            <view class="city-card-icon">
              <text>📍</text>
            </view>
            <text class="city-card-name">{{item}}</text>
          </view>
        </view>
      </scroll-view>
    </view>
    
    <view class="empty-city" wx:else>
      <text class="empty-city-text">还没有探访过其他城市</text>
    </view>
    
    <view class="stats-row">
      <view class="stat-item">
        <text class="stat-value">{{visitedCities.length}}</text>
        <text class="stat-label">城市</text>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item">
        <text class="stat-value">{{totalShops}}</text>
        <text class="stat-label">店铺</text>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item">
        <text class="stat-value">{{totalReviews}}</text>
        <text class="stat-label">点评</text>
      </view>
    </view>
  </view>

  <view class="shop-list" wx:if="{{shopGroups.length > 0}}">
    <view class="shop-group" wx:for="{{shopGroups}}" wx:key="shopName" bindtap="goToShopProfile" data-shop="{{item.shopName}}">
      <view class="shop-group-header">
        <view class="shop-info">
          <text class="shop-name">{{item.shopName}}</text>
          <text class="shop-category">{{item.category}}</text>
        </view>
        <view class="shop-badge">
          <text class="badge-icon">{{item.badge.icon}}</text>
          <text class="badge-text">{{item.badge.name}}</text>
        </view>
      </view>

      <view class="shop-stats">
        <view class="mini-stat">
          <text class="mini-stat-value">{{item.count}}次</text>
          <text class="mini-stat-label">光顾</text>
        </view>
        <view class="mini-stat">
          <text class="mini-stat-value">⭐{{item.avgRating}}</text>
          <text class="mini-stat-label">均分</text>
        </view>
        <view class="mini-stat">
          <text class="mini-stat-value">{{item.lastVisit}}</text>
          <text class="mini-stat-label">最近</text>
        </view>
      </view>

      <view class="rating-trend-bar" wx:if="{{item.count > 1}}">
        <view class="trend-item" wx:for="{{item.ratingHistory}}" wx:key="index" wx:for-item="rItem">
          <view class="trend-dot" style="height: {{rItem.height}}rpx; background-color: {{rItem.color}};"></view>
        </view>
      </view>
    </view>
  </view>

  <view class="empty-state" wx:else>
    <text class="empty-emoji">🗺️</text>
    <text class="empty-text">还没有探店足迹</text>
    <text class="empty-hint">快去发布第一条点评吧！</text>
  </view>
</view>