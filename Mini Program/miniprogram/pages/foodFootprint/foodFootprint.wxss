.container {
  min-height: 100vh;
  background-color: #f8f9fa;
  padding-bottom: 40rpx;
}

.header-summary {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 32rpx 28rpx;
  background: linear-gradient(135deg, #ff6b00 0%, #ff8533 100%);
  margin: 20rpx;
  border-radius: 16rpx;
}

.summary-emoji {
  font-size: 44rpx;
  margin-right: 16rpx;
}

.summary-text {
  font-size: 28rpx;
  color: #fff;
}

.summary-num {
  font-size: 36rpx;
  font-weight: 700;
  margin: 0 6rpx;
}

.map-section {
  padding: 0 20rpx;
  margin-bottom: 24rpx;
}

.map-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.map-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.map-subtitle {
  font-size: 24rpx;
  color: #999;
}

.city-cards {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 28rpx 0;
  box-shadow: 0 2rpx 12rpx rgba(255, 107, 0, 0.08);
  margin-bottom: 20rpx;
}

.city-scroll {
  white-space: nowrap;
}

.city-card-wrap {
  display: inline-flex;
  gap: 20rpx;
  padding: 0 20rpx;
}

.city-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-width: 140rpx;
  height: 160rpx;
  background: linear-gradient(135deg, #fff8f3 0%, #ffe8d9 100%);
  border-radius: 16rpx;
  border: 2rpx solid #ffd5b3;
  transition: all 0.2s ease;
}

.city-card-icon {
  width: 64rpx;
  height: 64rpx;
  background-color: rgba(255, 107, 0, 0.1);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12rpx;
}

.city-card-icon text {
  font-size: 32rpx;
}

.city-card-name {
  font-size: 26rpx;
  color: #ff6b00;
  font-weight: 600;
}

.empty-city {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 48rpx 28rpx;
  text-align: center;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  margin-bottom: 20rpx;
}

.empty-city-text {
  font-size: 26rpx;
  color: #999;
}

.stats-row {
  display: flex;
  justify-content: space-around;
  align-items: center;
  background-color: #fff;
  border-radius: 16rpx;
  padding: 28rpx 0;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.stat-item {
  text-align: center;
  flex: 1;
}

.stat-value {
  display: block;
  font-size: 40rpx;
  color: #ff6b00;
  font-weight: 700;
}

.stat-label {
  display: block;
  font-size: 22rpx;
  color: #999;
  margin-top: 6rpx;
}

.stat-divider {
  width: 2rpx;
  height: 52rpx;
  background-color: #f0f0f0;
}

.shop-list {
  padding: 0 20rpx;
}

.shop-group {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 24rpx 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.shop-group-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 16rpx;
}

.shop-info {
  flex: 1;
}

.shop-name {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 4rpx;
}

.shop-category {
  display: block;
  font-size: 22rpx;
  color: #999;
}

.shop-badge {
  display: flex;
  align-items: center;
  background-color: #fff8f3;
  padding: 6rpx 14rpx;
  border-radius: 20rpx;
}

.badge-icon {
  font-size: 26rpx;
  margin-right: 4rpx;
}

.badge-text {
  font-size: 20rpx;
  color: #ff6b00;
  font-weight: 500;
}

.shop-stats {
  display: flex;
  gap: 32rpx;
  margin-bottom: 16rpx;
}

.mini-stat {
  text-align: center;
}

.mini-stat-value {
  display: block;
  font-size: 28rpx;
  color: #333;
  font-weight: 600;
}

.mini-stat-label {
  display: block;
  font-size: 20rpx;
  color: #bbb;
  margin-top: 2rpx;
}

.rating-trend-bar {
  display: flex;
  align-items: flex-end;
  gap: 8rpx;
  height: 60rpx;
  padding-top: 8rpx;
}

.trend-dot {
  width: 20rpx;
  border-radius: 4rpx;
  transition: all 0.2s ease;
  min-height: 12rpx;
}

.empty-state {
  text-align: center;
  padding: 120rpx 28rpx;
}

.empty-emoji {
  display: block;
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  display: block;
  font-size: 32rpx;
  color: #666;
  font-weight: 500;
  margin-bottom: 12rpx;
}

.empty-hint {
  display: block;
  font-size: 26rpx;
  color: #bbb;
}