.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background-color: #f8f9fa;
}

.search-bar {
  padding: 16rpx 20rpx;
  background-color: #fff;
}

.search-input {
  background-color: #f5f5f5;
  border-radius: 32rpx;
  padding: 16rpx 24rpx;
  display: flex;
  align-items: center;
}

.search-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
}

.search-input text:last-child {
  font-size: 26rpx;
  color: #bbb;
}

.main-content {
  display: flex;
  flex: 1;
  overflow: hidden;
}

.category-sidebar {
  width: 180rpx;
  min-width: 180rpx;
  height: calc(100vh - 120rpx);
  background-color: #f5f5f5;
}

.category-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 28rpx 12rpx;
  position: relative;
  transition: all 0.2s ease;
}

.category-item.active {
  background-color: #fff;
}

.category-item.active::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 6rpx;
  height: 40rpx;
  background-color: #ff6b00;
  border-radius: 0 4rpx 4rpx 0;
}

.category-icon {
  font-size: 36rpx;
  margin-bottom: 6rpx;
}

.category-text {
  font-size: 24rpx;
  color: #666;
  text-align: center;
}

.category-item.active .category-text {
  color: #ff6b00;
  font-weight: 600;
}

.category-count {
  font-size: 18rpx;
  color: #ccc;
  margin-top: 4rpx;
}

.category-item.active .category-count {
  color: #ff6b00;
  opacity: 0.7;
}

.recipe-list {
  flex: 1;
  height: calc(100vh - 120rpx);
  padding: 20rpx;
  background-color: #fff;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #333;
}

.section-count {
  font-size: 22rpx;
  color: #999;
}

.recipe-card {
  display: flex;
  background-color: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
  border: 1rpx solid #f0f0f0;
}

.recipe-image {
  width: 200rpx;
  height: 200rpx;
  flex-shrink: 0;
}

.recipe-info {
  flex: 1;
  padding: 16rpx 20rpx;
  display: flex;
  flex-direction: column;
}

.recipe-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  line-height: 1.3;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-bottom: 10rpx;
}

.recipe-meta {
  display: flex;
  gap: 16rpx;
  margin-bottom: 10rpx;
}

.meta-item {
  display: flex;
  align-items: center;
  gap: 4rpx;
  font-size: 22rpx;
  color: #888;
}

.meta-icon {
  font-size: 20rpx;
}

.recipe-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-bottom: auto;
}

.tag {
  font-size: 20rpx;
  color: #ff6b00;
  background-color: #fff8f3;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.recipe-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 10rpx;
  padding-top: 10rpx;
  border-top: 1rpx solid #f5f5f5;
}

.rating-info {
  display: flex;
  align-items: center;
  gap: 4rpx;
}

.rating-value {
  font-size: 28rpx;
  color: #ff6b00;
  font-weight: 700;
}

.rating-star {
  font-size: 24rpx;
  color: #ff6b00;
}

.rating-count {
  font-size: 20rpx;
  color: #bbb;
}

.like-info {
  display: flex;
  align-items: center;
  gap: 4rpx;
  font-size: 22rpx;
  color: #bbb;
}

.loading-more,
.no-more {
  text-align: center;
  padding: 30rpx 0;
  font-size: 24rpx;
  color: #ccc;
}

.empty-state {
  text-align: center;
  padding: 100rpx 20rpx;
}

.empty-emoji {
  display: block;
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  display: block;
  font-size: 30rpx;
  color: #666;
  font-weight: 500;
  margin-bottom: 12rpx;
}

.empty-hint {
  display: block;
  font-size: 24rpx;
  color: #bbb;
}
