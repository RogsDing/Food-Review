<view class="container">
  <view class="user-info">
    <view class="user-avatar" bindtap="onAvatarTap">
      <image src="{{userInfo.avatarUrl || '/images/avatar.png'}}" mode="aspectFill" />
    </view>
    <view class="user-details">
      <text class="user-name">{{userInfo.nickName || '用户昵称'}}</text>
      <text class="user-meta">{{userInfo.nickName ? '已发布 ' + reviewCount + ' 条点评' : '当前尚未登录'}}</text>
      <button wx:if="{{!userInfo.nickName}}" class="login-btn" bindtap="login">点击登录</button>
    </view>
  </view>
  
  <view class="menu-list">
    <view class="menu-item" bindtap="goToMyReviews">
      <view class="menu-left">
        <view class="menu-icon"></view>
        <text class="menu-text">我的点评</text>
      </view>
      <view class="menu-arrow"></view>
    </view>
    <view class="menu-item" bindtap="goToSettings">
      <view class="menu-left">
        <view class="menu-icon"></view>
        <text class="menu-text">设置</text>
      </view>
      <view class="menu-arrow"></view>
    </view>
    <view class="menu-item" bindtap="goToAbout">
      <view class="menu-left">
        <view class="menu-icon"></view>
        <text class="menu-text">关于我们</text>
      </view>
      <view class="menu-arrow"></view>
    </view>
    <view class="menu-item" bindtap="goToFeedback">
      <view class="menu-left">
        <view class="menu-icon"></view>
        <text class="menu-text">意见反馈</text>
      </view>
      <view class="menu-arrow"></view>
    </view>
    <view class="menu-item" bindtap="goToFoodFootprint">
      <view class="menu-left">
        <view class="menu-icon footprint-icon">👣</view>
        <text class="menu-text">美食足迹</text>
      </view>
      <view class="menu-arrow"></view>
    </view>
  </view>

  <view wx:if="{{showEditModal}}" class="edit-modal">
    <view class="edit-modal-mask" bindtap="closeEditModal"></view>
    <view class="edit-modal-content">
      <view class="edit-modal-header">
        <text class="edit-modal-title">{{isLoggingIn ? '完善个人信息' : '编辑个人信息'}}</text>
        <view class="edit-modal-close" bindtap="closeEditModal">×</view>
      </view>
      <view class="edit-form">
        <view class="edit-avatar-section">
          <button class="avatar-button" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
            <image src="{{tempAvatarUrl || userInfo.avatarUrl || '/images/avatar.png'}}" mode="aspectFill" />
            <view class="edit-avatar-mask">{{isLoggingIn ? '点击设置头像' : '修改头像'}}</view>
          </button>
        </view>
        <view class="edit-item">
          <text class="edit-label">昵称</text>
          <input class="edit-input" type="nickname" placeholder="请输入昵称" value="{{userInfo.nickName}}" bindinput="onNickNameInput" />
        </view>
      </view>
      <view class="edit-modal-footer">
        <button class="edit-btn cancel" bindtap="closeEditModal">取消</button>
        <button class="edit-btn save" bindtap="saveUserProfile">{{isLoggingIn ? '登录' : '保存'}}</button>
      </view>
    </view>
  </view>
  
  <!-- 关于我们弹窗 -->
  <view wx:if="{{showAboutModal}}" class="custom-modal" bindtap="closeAboutModal">
    <view class="modal-content" catchtap="catchTap">
      <view class="modal-header">
        <text class="modal-title">关于我们</text>
      </view>
      <view class="modal-body">
        <view class="about-logo">🍽️</view>
        <text class="modal-text title">美食点评小程序</text>
        <text class="modal-text version">v1.0.0</text>
        <text class="modal-text">一个帮助您记录和管理美食体验的工具</text>
        <text class="modal-text">发现美食，分享快乐</text>
        <text class="modal-text copyright">© 2026 美食点评</text>
      </view>
      <view class="modal-footer">
        <button class="modal-btn" bindtap="closeAboutModal">确定</button>
      </view>
    </view>
  </view>
  
  <!-- 意见反馈弹窗 -->
  <view wx:if="{{showFeedbackModal}}" class="custom-modal feedback-modal" bindtap="closeFeedbackModal">
    <view class="modal-content feedback-content" catchtap="catchTap">
      <view class="modal-header">
        <text class="modal-title">意见反馈</text>
      </view>
      <view class="modal-body feedback-body">
        <textarea class="feedback-input" placeholder="请输入您的意见或建议（最多500字）" maxlength="500" value="{{feedbackContent}}" bindinput="onFeedbackInput" auto-height />
        <view class="feedback-count">{{feedbackContent.length}}/500</view>
      </view>
      <view class="modal-footer feedback-footer">
        <button class="feedback-btn cancel" bindtap="closeFeedbackModal">取消</button>
        <button class="feedback-btn submit" bindtap="submitFeedback">提交反馈</button>
      </view>
    </view>
  </view>
</view>