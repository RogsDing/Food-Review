<view class="container">
  <!-- 顶部搜索栏 -->
  <view class="search-bar" bindtap="goToSearch">
    <view class="search-input">
      <text class="search-icon">🔍</text>
      <text>搜索商家、美食</text>
    </view>
  </view>
  
  <!-- 分类导航 -->
  <view class="category-nav">
    <view class="category-list">
      <view class="category-item" bindtap="selectCategory" data-category="川菜">
        <view class="category-icon">🌶️</view>
        <text class="category-text">川菜</text>
      </view>
      <view class="category-item" bindtap="selectCategory" data-category="湘菜">
        <view class="category-icon">🥘</view>
        <text class="category-text">湘菜</text>
      </view>
      <view class="category-item" bindtap="selectCategory" data-category="江西菜">
        <view class="category-icon">🍲</view>
        <text class="category-text">江西菜</text>
      </view>
      <view class="category-item" bindtap="selectCategory" data-category="自助">
        <view class="category-icon">🍴</view>
        <text class="category-text">自助</text>
      </view>
      <view class="category-item" bindtap="selectCategory" data-category="韩料">
        <view class="category-icon">🥓</view>
        <text class="category-text">韩料</text>
      </view>
      <view class="category-item" bindtap="selectCategory" data-category="日料">
        <view class="category-icon">🍱</view>
        <text class="category-text">日料</text>
      </view>
      <view class="category-item" bindtap="selectCategory" data-category="西餐">
        <view class="category-icon">🍔</view>
        <text class="category-text">西餐</text>
      </view>
      <view class="category-item" bindtap="selectCategory" data-category="火锅">
        <view class="category-icon">🥘</view>
        <text class="category-text">火锅</text>
      </view>
      <view class="category-item" bindtap="selectCategory" data-category="烧烤">
        <view class="category-icon">🍖</view>
        <text class="category-text">烧烤</text>
      </view>
    </view>
  </view>
  
  <!-- 筛选栏 -->
  <view class="filter-bar">
    <view class="filter-item" bindtap="showSortOptions">
      <text>综合排序</text>
      <view class="filter-arrow"></view>
    </view>
    <view class="filter-item" bindtap="showAreaOptions">
      <text>附近</text>
      <view class="filter-arrow"></view>
    </view>
    <view class="filter-item" bindtap="showCategoryOptions">
      <text>{{categoryText}}</text>
      <view class="filter-arrow"></view>
    </view>
    <view class="filter-item" bindtap="showFilterOptions">
      <text>筛选</text>
      <view class="filter-arrow"></view>
    </view>
  </view>

  <!-- 分类选项 -->
  <view wx:if="{{showCategory}}" class="option-panel" bindtap="hideCategoryOptions">
    <view class="option-content" catchtap="catchTap">
      <view class="option-item" wx:for="{{categories}}" wx:key="{{index}}" bindtap="selectCategory" data-category="{{item}}">
        <text>{{item}}</text>
      </view>
    </view>
  </view>
  
  <!-- 商家列表 -->
  <view class="shop-list">
    <block wx:for="{{reviews}}" wx:key="_id">
      <view class="shop-card" bindtap="goToDetail" data-id="{{item._id}}">
        <view class="shop-image" wx:if="{{item.imageFileIDs && item.imageFileIDs.length > 0}}">
          <image src="{{item.imageFileIDs[0]}}" mode="aspectFill" />
        </view>
        <view class="shop-info">
          <view class="shop-header">
            <text class="shop-name">{{item.shopName}}</text>
            <view class="shop-rating">
              <text>{{item.rating}}</text>
              <text class="star">★</text>
            </view>
          </view>
          <view class="shop-meta">
            <text>人均 ¥{{item.averagePrice || 0}}</text>
          </view>
          <view class="shop-tags">

            <text class="shop-tag">{{item.category || '美食'}}</text>
          </view>
          <view class="shop-bottom">
            <text class="shop-address">{{item.address || item.area}}</text>
            <text class="shop-distance">{{item.distance || '1.2km'}}</text>
          </view>
        </view>
      </view>
    </block>
    
    <!-- 空状态 -->
    <view wx:if="{{reviews.length === 0}}" class="empty-state">
      <text class="empty-state-text">暂无点评记录</text>
      <button class="empty-btn" bindtap="goToPublish">发布第一条点评</button>
    </view>
    
    <!-- 加载更多 -->
    <view wx:if="{{reviews.length > 0}}" class="load-more">
      <text>上拉加载更多</text>
    </view>
  </view>
  
  <!-- 排序选项 -->
  <view wx:if="{{showSort}}" class="option-panel" bindtap="hideSortOptions">
    <view class="option-content" catchtap="catchTap">
      <view class="option-item" bindtap="sortByRatingDesc">
        <text>评分从高到低</text>
      </view>
      <view class="option-item" bindtap="sortByRatingAsc">
        <text>评分从低到高</text>
      </view>
      <view class="option-item" bindtap="sortByTimeDesc">
        <text>时间从新到旧</text>
      </view>
      <view class="option-item" bindtap="sortByTimeAsc">
        <text>时间从旧到新</text>
      </view>
    </view>
  </view>
  
  <!-- 地区选项 -->
  <view wx:if="{{showArea}}" class="option-panel" bindtap="hideAreaOptions">
    <view class="option-content" catchtap="catchTap">
      <!-- 多级选择器 -->
      <view class="region-picker">
        <picker mode="multiSelector" bindchange="bindRegionChange" bindcolumnchange="bindRegionColumnChange" value="{{regionIndex}}" range="{{regionOptions}}">
          <view class="picker-input">
            {{province}} {{city}}
          </view>
        </picker>
      </view>
    </view>
  </view>
</view>