.container {
  min-height: 100vh;
  background-color: #f5f5f5;
  display: flex;
  flex-direction: column;
}

/* 顶部搜索栏 */
.search-bar {
  padding: 16rpx 20rpx;
  background-color: #f5f5f5;
  display: flex;
  align-items: center;
  cursor: pointer;
}

.search-input {
  flex: 1;
  height: 64rpx;
  background-color: #fff;
  border-radius: 32rpx;
  border: 2rpx solid #ff6b00;
  padding: 0 60rpx 0 60rpx;
  font-size: 26rpx;
  display: flex;
  align-items: center;
  position: relative;
}

.search-icon {
  position: absolute;
  left: 24rpx;
  color: #999;
  font-size: 28rpx;
}




/* 分类导航 */
.category-nav {
  background-color: #fff;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
  overflow-x: auto;
  white-space: nowrap;
}

.category-list {
  display: flex;
  padding: 0 20rpx;
  gap: 32rpx;
}

.category-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 0;
}

.category-icon {
  width: 64rpx;
  height: 64rpx;
  background-color: #f8f9fa;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
}

.category-text {
  font-size: 22rpx;
  color: #333;
}

/* 商家列表 */
.shop-list {
  flex: 1;
  padding: 16rpx;
  overflow-y: auto;
}

.shop-card {
  background-color: #fff;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  transition: all 0.3s ease;
}

.shop-card:hover {
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
  transform: translateY(-2rpx);
}

.shop-image {
  width: 100%;
  height: 240rpx;
  overflow: hidden;
}

.shop-image image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.shop-info {
  padding: 16rpx;
}

.shop-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.shop-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  flex: 1;
  margin-right: 16rpx;
}

.shop-rating {
  background-color: #ff6b00;
  color: #fff;
  font-size: 22rpx;
  font-weight: 600;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  gap: 4rpx;
}

.shop-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 12rpx;
  font-size: 22rpx;
  color: #666;
}

.shop-tags {
  display: flex;
  gap: 8rpx;
  flex-wrap: wrap;
  margin-bottom: 12rpx;
}

.shop-tag {
  font-size: 20rpx;
  color: #ff6b00;
  background-color: #fff3e6;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
  border: 1rpx solid #ffd5b3;
}

.shop-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-size: 20rpx;
  color: #999;
}

.shop-address {
  flex: 1;
  margin-right: 16rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.shop-distance {
  white-space: nowrap;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
  color: #999;
  flex: 1;
}

.empty-state-icon {
  width: 120rpx;
  height: 120rpx;
  margin-bottom: 32rpx;
  opacity: 0.5;
}

.empty-state-text {
  font-size: 28rpx;
  margin-bottom: 32rpx;
}

.empty-btn {
  background-color: #ff6b00;
  color: #fff;
  border: none;
  border-radius: 40rpx;
  padding: 0 32rpx;
  height: 80rpx;
  font-size: 28rpx;
  font-weight: 500;
  box-shadow: 0 2rpx 6rpx rgba(255, 107, 0, 0.3);
  transition: all 0.3s ease;
}

.empty-btn:hover {
  background-color: #ff8533;
  box-shadow: 0 3rpx 8rpx rgba(255, 107, 0, 0.4);
}

.empty-btn::after {
  border: none;
}

/* 响应式调整 */
@media (max-width: 375px) {
  .search-bar {
    padding: 12rpx 16rpx;
  }
  
  .search-input {
    height: 56rpx;
    font-size: 24rpx;
  }
  
  .search-btn {
    height: 56rpx;
    font-size: 24rpx;
  }
  
  .category-nav {
    padding: 16rpx 0;
  }
  
  .category-list {
    gap: 24rpx;
  }
  
  .category-icon {
    width: 56rpx;
    height: 56rpx;
    font-size: 28rpx;
  }
  
  .category-text {
    font-size: 20rpx;
  }
  
  .shop-list {
    padding: 12rpx;
  }
  
  .shop-card {
    margin-bottom: 12rpx;
  }
  
  .shop-image {
    height: 200rpx;
  }
  
  .shop-info {
    padding: 12rpx;
  }
  
  .shop-name {
    font-size: 26rpx;
  }
  
  .shop-rating {
    font-size: 20rpx;
  }
  
  .shop-meta {
    font-size: 20rpx;
    gap: 12rpx;
  }
  
  .shop-tag {
    font-size: 18rpx;
  }
  
  .shop-bottom {
    font-size: 18rpx;
  }
}

/* 动画效果 */
@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.shop-card {
  animation: fadeIn 0.3s ease-out;
}

/* 加载更多 */
.load-more {
  text-align: center;
  padding: 32rpx 0;
  font-size: 24rpx;
  color: #999;
}

/* 筛选栏 */
.filter-bar {
  background-color: #fff;
  padding: 16rpx 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.filter-item {
  display: flex;
  align-items: center;
  font-size: 24rpx;
  color: #333;
  gap: 4rpx;
}

.filter-arrow {
  width: 12rpx;
  height: 12rpx;
  border-right: 2rpx solid #999;
  border-bottom: 2rpx solid #999;
  transform: rotate(45deg);
  transition: all 0.3s ease;
}

/* 评分星星 */
.star {
  width: 20rpx;
  height: 20rpx;
  background-color: #ffd700;
  clip-path: polygon(50% 0%, 61% 35%, 98% 35%, 68% 57%, 79% 91%, 50% 70%, 21% 91%, 32% 57%, 2% 35%, 39% 35%);
  display: inline-block;
}

/* 选项面板 */
.option-panel {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: flex-end;
  justify-content: center;
  z-index: 1000;
}

.option-content {
  background-color: #fff;
  width: 100%;
  border-top-left-radius: 20rpx;
  border-top-right-radius: 20rpx;
  padding: 24rpx;
  max-height: 80vh;
  overflow-y: auto;
}

.option-item {
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
  font-size: 28rpx;
  color: #333;
  text-align: center;
}

.option-item:last-child {
  border-bottom: none;
}

.option-item:hover {
  background-color: #f5f5f5;
  border-radius: 8rpx;
  margin: 0 -24rpx;
  padding-left: 24rpx;
  padding-right: 24rpx;
}
