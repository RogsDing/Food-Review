.container {
  min-height: 100vh;
  background-color: #f5f5f5;
  display: flex;
  flex-direction: column;
}

/* 搜索栏 */
.search-bar {
  padding: 16rpx 20rpx;
  background-color: #ff6b00;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.search-input-container {
  flex: 4;
  height: 64rpx;
  background-color: #fff;
  border-radius: 32rpx;
  border: none;
  padding: 0 60rpx 0 60rpx;
  font-size: 26rpx;
  display: flex;
  align-items: center;
  position: relative;
}

.search-input {
  flex: 1;
  height: 100%;
  border: none;
  outline: none;
  font-size: 26rpx;
}

.search-input::placeholder {
  color: #999;
}

.search-icon {
  position: absolute;
  left: 24rpx;
  color: #999;
  font-size: 28rpx;
}

.search-clear {
  position: absolute;
  right: 24rpx;
  color: #999;
  font-size: 32rpx;
  font-weight: bold;
  cursor: pointer;
  padding: 8rpx;
}

.cancel-btn {
  flex: 1;
  height: 64rpx;
  padding: 0 20rpx;
  background-color: transparent;
  color: #fff;
  border: none;
  font-size: 26rpx;
  font-weight: 500;
  min-width: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.cancel-btn::after {
  border: none;
}

/* 搜索历史 */
.search-history {
  padding: 24rpx;
  background-color: #fff;
  margin: 16rpx;
  border-radius: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.history-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.history-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #333;
}

.clear-history {
  font-size: 22rpx;
  color: #999;
}

.history-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.history-item {
  font-size: 22rpx;
  color: #666;
  background-color: #f5f5f5;
  padding: 12rpx 20rpx;
  border-radius: 20rpx;
}

/* 搜索建议 */
.search-suggestions {
  padding: 24rpx;
  background-color: #fff;
  margin: 0 16rpx 16rpx 16rpx;
  border-radius: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.suggestion-header {
  margin-bottom: 16rpx;
}

.suggestion-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #333;
}

.suggestion-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.suggestion-item {
  font-size: 24rpx;
  color: #666;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.suggestion-item:last-child {
  border-bottom: none;
}

/* 搜索结果 */
.search-results {
  flex: 1;
  padding: 16rpx;
  overflow-y: auto;
}

.results-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
  padding: 0 8rpx;
}

.results-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #333;
}

.results-count {
  font-size: 22rpx;
  color: #999;
}

/* 商家卡片 */
.shop-card {
  background-color: #fff;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  transition: all 0.3s ease;
}

.shop-card:hover {
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
  transform: translateY(-2rpx);
}

.shop-image {
  width: 100%;
  height: 240rpx;
  overflow: hidden;
}

.shop-image image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.shop-info {
  padding: 16rpx;
}

.shop-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.shop-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  flex: 1;
  margin-right: 16rpx;
}

.shop-rating {
  background-color: #ff6b00;
  color: #fff;
  font-size: 22rpx;
  font-weight: 600;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  gap: 4rpx;
}

.shop-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 12rpx;
  font-size: 22rpx;
  color: #666;
}

.shop-tags {
  display: flex;
  gap: 8rpx;
  flex-wrap: wrap;
  margin-bottom: 12rpx;
}

.shop-tag {
  font-size: 20rpx;
  color: #ff6b00;
  background-color: #fff3e6;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
  border: 1rpx solid #ffd5b3;
}

.shop-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-size: 20rpx;
  color: #999;
}

.shop-address {
  flex: 1;
  margin-right: 16rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.shop-distance {
  white-space: nowrap;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
  color: #999;
  flex: 1;
}

.empty-state-text {
  font-size: 28rpx;
  margin-bottom: 32rpx;
}

/* 评分星星 */
.star {
  width: 20rpx;
  height: 20rpx;
  background-color: #ffd700;
  clip-path: polygon(50% 0%, 61% 35%, 98% 35%, 68% 57%, 79% 91%, 50% 70%, 21% 91%, 32% 57%, 2% 35%, 39% 35%);
  display: inline-block;
}

/* 响应式调整 */
@media (max-width: 375px) {
  .search-bar {
    padding: 12rpx 16rpx;
  }
  
  .search-input-container {
    height: 56rpx;
    padding: 0 50rpx 0 50rpx;
  }
  
  .search-input {
    font-size: 24rpx;
  }
  
  .cancel-btn {
    height: 56rpx;
    font-size: 24rpx;
  }
  
  .search-history,
  .search-suggestions {
    padding: 20rpx;
    margin: 12rpx;
  }
  
  .history-title,
  .suggestion-title {
    font-size: 24rpx;
  }
  
  .history-item {
    font-size: 20rpx;
    padding: 10rpx 16rpx;
  }
  
  .suggestion-item {
    font-size: 22rpx;
  }
  
  .search-results {
    padding: 12rpx;
  }
  
  .shop-card {
    margin-bottom: 12rpx;
  }
  
  .shop-image {
    height: 200rpx;
  }
  
  .shop-info {
    padding: 12rpx;
  }
  
  .shop-name {
    font-size: 26rpx;
  }
  
  .shop-rating {
    font-size: 20rpx;
  }
  
  .shop-meta {
    font-size: 20rpx;
    gap: 12rpx;
  }
  
  .shop-tag {
    font-size: 18rpx;
  }
  
  .shop-bottom {
    font-size: 18rpx;
  }
}