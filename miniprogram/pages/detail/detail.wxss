.container {
  min-height: 100vh;
  background-color: #f8f9fa;
  padding-bottom: 120rpx;
}

.detail-header {
  background-color: #fff;
  padding: 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
  box-shadow: 0 1rpx 3rpx rgba(0, 0, 0, 0.05);
}

.detail-shop-name {
  font-size: 36rpx;
  font-weight: 600;
  display: block;
  margin-bottom: 16rpx;
  color: #333;
  line-height: 1.3;
}

.detail-meta {
  display: flex;
  align-items: center;
  gap: 24rpx;
  font-size: 26rpx;
  color: #666;
  margin-bottom: 16rpx;
  flex-wrap: wrap;
}

.review-rating {
  display: flex;
  align-items: center;
}

.star {
  width: 32rpx;
  height: 32rpx;
  margin-left: 8rpx;
  background-color: #e0e0e0;
  clip-path: polygon(50% 0%, 61% 35%, 98% 35%, 68% 57%, 79% 91%, 50% 70%, 21% 91%, 32% 57%, 2% 35%, 39% 35%);
  transition: all 0.3s ease;
}

.star.active {
  background-color: #ffd700;
  transform: scale(1.1);
}

.detail-content {
  background-color: #fff;
  padding: 24rpx;
  margin-top: 20rpx;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
  margin: 20rpx;
}

.detail-text {
  font-size: 28rpx;
  line-height: 1.6;
  margin-bottom: 24rpx;
  display: block;
  color: #333;
}

.detail-images {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.detail-image {
  width: calc(33.333% - 10.666rpx);
  aspect-ratio: 1;
  border-radius: 12rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.1);
  transition: all 0.3s ease;
  cursor: pointer;
}

.detail-image:hover {
  transform: scale(1.02);
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.15);
}

.detail-image image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.detail-actions {
  position: fixed;
  bottom: 80rpx;
  left: 20rpx;
  right: 20rpx;
  background-color: #fff;
  padding: 20rpx;
  border-radius: 16rpx;
  box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.05);
  display: flex;
  gap: 16rpx;
}

.action-btn {
  flex: 1;
  height: 80rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 40rpx;
  font-size: 28rpx;
  background-color: #fff;
  color: #666;
  font-weight: 500;
  transition: all 0.3s ease;
  display: flex;
  align-items: center;
  justify-content: center;
}

.action-btn:hover {
  border-color: #d0d0d0;
  background-color: #f5f5f5;
  transform: translateY(-2rpx);
}

.action-btn.primary {
  background-color: #ff6b00;
  color: #fff;
  border-color: #ff6b00;
  box-shadow: 0 2rpx 6rpx rgba(255, 107, 0, 0.3);
}

.action-btn.primary:hover {
  background-color: #ff8533;
  box-shadow: 0 3rpx 8rpx rgba(255, 107, 0, 0.4);
}

.action-btn::after {
  border: none;
}

/* 响应式调整 */
@media (max-width: 375px) {
  .detail-header {
    padding: 20rpx;
  }
  
  .detail-shop-name {
    font-size: 32rpx;
  }
  
  .detail-meta {
    font-size: 24rpx;
    gap: 20rpx;
  }
  
  .detail-content {
    padding: 20rpx;
    margin: 16rpx;
  }
  
  .detail-text {
    font-size: 26rpx;
  }
  
  .detail-image {
    width: calc(33.333% - 8rpx);
    gap: 12rpx;
  }
  
  .action-btn {
    height: 72rpx;
    font-size: 26rpx;
  }
}