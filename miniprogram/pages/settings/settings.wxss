.container {
  min-height: 100vh;
  background-color: #f8f9fa;
  padding-bottom: 40rpx;
}

.section {
  background-color: #fff;
  margin: 20rpx;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
  overflow: hidden;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 24rpx;
  color: #999;
  padding: 20rpx 24rpx 12rpx;
  font-weight: 500;
}

.setting-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
  transition: all 0.3s ease;
  cursor: pointer;
}

.setting-item:hover {
  background-color: #f8f9fa;
  transform: translateX(4rpx);
}

.setting-item:last-child {
  border-bottom: none;
}

.setting-label {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.setting-control {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.setting-arrow {
  display: flex;
  align-items: center;
}

.menu-arrow {
  width: 16rpx;
  height: 16rpx;
  border-right: 2rpx solid #999;
  border-bottom: 2rpx solid #999;
  transform: rotate(-45deg);
  transition: all 0.3s ease;
}

.setting-item:hover .menu-arrow {
  border-color: #ff6b00;
  transform: rotate(-45deg) translateX(4rpx) translateY(-4rpx);
}

.setting-value {
  font-size: 26rpx;
  color: #999;
}

/* 开关组件样式 */
.switch {
  position: relative;
  width: 80rpx;
  height: 44rpx;
  background-color: #e0e0e0;
  border-radius: 22rpx;
  transition: all 0.3s ease;
  cursor: pointer;
}

.switch.active {
  background-color: #ff6b00;
}

.switch::after {
  content: '';
  position: absolute;
  top: 4rpx;
  left: 4rpx;
  width: 36rpx;
  height: 36rpx;
  background-color: #fff;
  border-radius: 50%;
  transition: all 0.3s ease;
  box-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.15);
}

.switch.active::after {
  transform: translateX(36rpx);
}

.logout-btn {
  margin: 40rpx 20rpx 0;
  height: 88rpx;
  background-color: #fff;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #ff6b00;
  border: 2rpx solid #ff6b00;
  font-weight: 500;
  transition: all 0.3s ease;
  box-shadow: 0 2rpx 6rpx rgba(255, 107, 0, 0.1);
}

.logout-btn:hover {
  background-color: #ff6b00;
  color: #fff;
  box-shadow: 0 4rpx 12rpx rgba(255, 107, 0, 0.3);
  transform: translateY(-2rpx);
}

/* 响应式调整 */
@media (max-width: 375px) {
  .section {
    margin: 16rpx;
    margin-bottom: 20rpx;
  }
  
  .section-title {
    padding: 16rpx 20rpx 10rpx;
    font-size: 22rpx;
  }
  
  .setting-item {
    padding: 20rpx;
  }
  
  .setting-label {
    font-size: 26rpx;
  }
  
  .setting-value {
    font-size: 24rpx;
  }
  
  .logout-btn {
    margin: 32rpx 16rpx 0;
    height: 80rpx;
    font-size: 26rpx;
  }
}

/* 自定义弹窗样式 */
.custom-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
  animation: fadeIn 0.3s ease;
}

.modal-content {
  width: 80%;
  max-width: 560rpx;
  background-color: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  animation: slideUp 0.3s ease;
}

.modal-header {
  padding: 32rpx;
  text-align: center;
  border-bottom: 1rpx solid #f0f0f0;
  background: linear-gradient(135deg, #ff6b00 0%, #ff8533 100%);
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
}

.modal-body {
  padding: 40rpx 32rpx;
  text-align: center;
}

.about-logo {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.modal-text {
  display: block;
  font-size: 28rpx;
  color: #666;
  line-height: 1.8;
  margin-bottom: 16rpx;
}

.modal-text.title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 8rpx;
}

.modal-text.version {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 24rpx;
}

.modal-text.copyright {
  font-size: 22rpx;
  color: #999;
  margin-top: 24rpx;
}

.modal-footer {
  padding: 24rpx 32rpx;
  border-top: 1rpx solid #f0f0f0;
}

.modal-btn {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #ff6b00 0%, #ff8533 100%);
  color: #fff;
  font-size: 30rpx;
  font-weight: 500;
  border-radius: 44rpx;
  border: none;
  box-shadow: 0 4rpx 12rpx rgba(255, 107, 0, 0.3);
  transition: all 0.3s ease;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-btn:hover {
  transform: translateY(-2rpx);
  box-shadow: 0 6rpx 16rpx rgba(255, 107, 0, 0.4);
}

.modal-btn::after {
  border: none;
}

/* 弹窗动画 */
@keyframes fadeIn {
  from {
    opacity: 0;
  }
  to {
    opacity: 1;
  }
}

@keyframes slideUp {
  from {
    opacity: 0;
    transform: translateY(40rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}
