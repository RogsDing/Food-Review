<view class="container">
  <view class="section">
    <text class="section-title">消息通知</text>
    <view class="setting-item">
      <text class="setting-label">点评通知</text>
      <view class="setting-control">
        <switch checked="{{notificationEnabled}}" bindchange="toggleNotification" />
      </view>
    </view>
  </view>
  
  <view class="section">
    <text class="section-title">通用设置</text>
    <view class="setting-item" bindtap="clearCache">
      <text class="setting-label">清除缓存</text>
      <view class="setting-arrow">
        <view class="menu-arrow"></view>
      </view>
    </view>
  </view>
  
  <view class="section">
    <text class="section-title">关于</text>
    <view class="setting-item">
      <text class="setting-label">版本号</text>
      <text class="setting-value">1.0.0</text>
    </view>
  </view>
  
  <view class="logout-btn" bindtap="logout">
    <text>退出登录</text>
  </view>
  
  <!-- 自定义关于弹窗 -->
  <view wx:if="{{showAboutModal}}" class="custom-modal" bindtap="closeAboutModal">
    <view class="modal-content" catchtap="catchTap">
      <view class="modal-header">
        <text class="modal-title">关于我们</text>
      </view>
      <view class="modal-body">
        <view class="about-logo">🍽️</view>
        <text class="modal-text title">美食点评小程序</text>
        <text class="modal-text version">v1.0.0</text>
        <text class="modal-text">一个帮助您记录和管理美食体验的工具</text>
        <text class="modal-text">发现美食，分享快乐</text>
        <text class="modal-text copyright">© 2026 美食点评</text>
      </view>
      <view class="modal-footer">
        <button class="modal-btn" bindtap="closeAboutModal">确定</button>
      </view>
    </view>
  </view>
</view>