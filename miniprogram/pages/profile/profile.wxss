.container {
  min-height: 100vh;
  background-color: #f8f9fa;
}

.user-info {
  background: linear-gradient(135deg, #ff6b00 0%, #ff8533 100%);
  color: #fff;
  padding: 40rpx 24rpx;
  display: flex;
  align-items: center;
  gap: 24rpx;
  border-radius: 0 0 24rpx 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(255, 107, 0, 0.3);
}

.user-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  overflow: hidden;
  background-color: rgba(255, 255, 255, 0.3);
  border: 4rpx solid rgba(255, 255, 255, 0.5);
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
  transition: all 0.3s ease;
}

.user-avatar:hover {
  transform: scale(1.05);
  box-shadow: 0 6rpx 16rpx rgba(0, 0, 0, 0.15);
}

.user-avatar image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.user-details {
  flex: 1;
}

.user-name {
  font-size: 36rpx;
  font-weight: 600;
  margin-bottom: 8rpx;
  display: block;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.1);
}

.user-meta {
  font-size: 26rpx;
  opacity: 0.9;
  display: block;
  text-shadow: 0 1rpx 2rpx rgba(0, 0, 0, 0.1);
  margin-bottom: 12rpx;
}

.login-btn {
  background-color: rgba(255, 255, 255, 0.9);
  color: #ff6b00;
  font-size: 24rpx;
  font-weight: 600;
  padding: 8rpx 24rpx;
  border-radius: 20rpx;
  border: none;
  margin-top: 8rpx;
  transition: all 0.3s ease;
}

.login-btn:hover {
  background-color: #fff;
  transform: translateY(-2rpx);
  box-shadow: 0 4rpx 8rpx rgba(0, 0, 0, 0.1);
}

.menu-list {
  background-color: #fff;
  margin: 24rpx 20rpx;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
  overflow: hidden;
}

.menu-item {
  padding: 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  transition: all 0.3s ease;
  cursor: pointer;
}

.menu-item:hover {
  background-color: #f8f9fa;
  transform: translateX(4rpx);
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon {
  width: 48rpx;
  height: 48rpx;
  background-color: #f0f0f0;
  border-radius: 12rpx;
  margin-right: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #666;
  transition: all 0.3s ease;
}

.menu-item:hover .menu-icon {
  background-color: #ff6b00;
  color: #fff;
  transform: scale(1.1);
}

.menu-left {
  display: flex;
  align-items: center;
}

.menu-text {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.menu-arrow {
  width: 16rpx;
  height: 16rpx;
  border-right: 2rpx solid #999;
  border-bottom: 2rpx solid #999;
  transform: rotate(-45deg);
  transition: all 0.3s ease;
}

.menu-item:hover .menu-arrow {
  border-color: #ff6b00;
  transform: rotate(-45deg) translateX(4rpx) translateY(-4rpx);
}

.menu-badge {
  background-color: #ff6b00;
  color: #fff;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
  margin-left: 12rpx;
  font-weight: 500;
}

.edit-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
}

.edit-modal-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
}

.edit-modal-content {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: #fff;
  border-radius: 24rpx 24rpx 0 0;
  padding: 32rpx 24rpx;
  max-height: 80vh;
  overflow-y: auto;
}

.edit-modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 32rpx;
}

.edit-modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.edit-modal-close {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  color: #999;
}

.edit-form {
  padding: 0 16rpx;
}

.edit-avatar-section {
  display: flex;
  justify-content: center;
  margin-bottom: 32rpx;
}

.avatar-button {
  width: 180rpx;
  height: 180rpx;
  border-radius: 90rpx;
  overflow: hidden;
  position: relative;
  background: transparent;
  border: none;
  padding: 0;
  margin: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  line-height: 1;
  -webkit-appearance: none;
  appearance: none;
  outline: none;
}

.avatar-button::after {
  border: none;
  width: 0;
  height: 0;
}

.avatar-button image {
  width: 180rpx;
  height: 180rpx;
  object-fit: cover;
  border-radius: 90rpx;
}

.avatar-button .edit-avatar-mask {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: rgba(0, 0, 0, 0.5);
  color: #fff;
  font-size: 24rpx;
  text-align: center;
  padding: 8rpx 0;
}

.edit-item {
  margin-bottom: 24rpx;
}

.edit-label {
  display: block;
  font-size: 28rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.edit-input {
  width: 100%;
  height: 80rpx;
  background-color: #f8f9fa;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.edit-modal-footer {
  display: flex;
  gap: 24rpx;
  margin-top: 32rpx;
}

.edit-btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 600;
}

.edit-btn.cancel {
  background-color: #f0f0f0;
  color: #666;
}

.edit-btn.save {
  background: linear-gradient(135deg, #ff6b00 0%, #ff8533 100%);
  color: #fff;
}

/* 响应式调整 */
@media (max-width: 375px) {
  .user-info {
    padding: 32rpx 20rpx;
  }
  
  .user-avatar {
    width: 100rpx;
    height: 100rpx;
  }
  
  .user-name {
    font-size: 32rpx;
  }
  
  .user-meta {
    font-size: 24rpx;
  }
  
  .menu-list {
    margin: 20rpx 16rpx;
  }
  
  .menu-item {
    padding: 20rpx;
  }
  
  .menu-icon {
    width: 40rpx;
    height: 40rpx;
    margin-right: 16rpx;
  }
  
  .menu-text {
    font-size: 26rpx;
  }
}