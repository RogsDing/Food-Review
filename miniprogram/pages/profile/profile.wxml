<view class="container">
  <view class="user-info">
    <view class="user-avatar" bindtap="onAvatarTap">
      <image src="{{userInfo.avatarUrl || '/images/avatar.png'}}" mode="aspectFill" />
    </view>
    <view class="user-details">
      <text class="user-name">{{userInfo.nickName || '用户昵称'}}</text>
      <text class="user-meta">{{userInfo.nickName ? '已发布 ' + reviewCount + ' 条点评' : '当前尚未登录'}}</text>
      <button wx:if="{{!userInfo.nickName}}" class="login-btn" bindtap="login">点击登录</button>
    </view>
  </view>
  
  <view class="menu-list">
    <view class="menu-item" bindtap="goToMyReviews">
      <view class="menu-left">
        <view class="menu-icon"></view>
        <text class="menu-text">我的点评</text>
      </view>
      <view class="menu-arrow"></view>
    </view>
    <view class="menu-item" bindtap="goToSettings">
      <view class="menu-left">
        <view class="menu-icon"></view>
        <text class="menu-text">设置</text>
      </view>
      <view class="menu-arrow"></view>
    </view>
    <view class="menu-item" bindtap="goToAbout">
      <view class="menu-left">
        <view class="menu-icon"></view>
        <text class="menu-text">关于我们</text>
      </view>
      <view class="menu-arrow"></view>
    </view>
  </view>

  <view wx:if="{{showEditModal}}" class="edit-modal">
    <view class="edit-modal-mask" bindtap="closeEditModal"></view>
    <view class="edit-modal-content">
      <view class="edit-modal-header">
        <text class="edit-modal-title">{{isLoggingIn ? '完善个人信息' : '编辑个人信息'}}</text>
        <view class="edit-modal-close" bindtap="closeEditModal">×</view>
      </view>
      <view class="edit-form">
        <view class="edit-avatar-section">
          <button class="avatar-button" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
            <image src="{{tempAvatarUrl || userInfo.avatarUrl || '/images/avatar.png'}}" mode="aspectFill" />
            <view class="edit-avatar-mask">{{isLoggingIn ? '点击设置头像' : '修改头像'}}</view>
          </button>
        </view>
        <view class="edit-item">
          <text class="edit-label">昵称</text>
          <input class="edit-input" type="nickname" placeholder="请输入昵称" value="{{userInfo.nickName}}" bindinput="onNickNameInput" />
        </view>
      </view>
      <view class="edit-modal-footer">
        <button class="edit-btn cancel" bindtap="closeEditModal">取消</button>
        <button class="edit-btn save" bindtap="saveUserProfile">{{isLoggingIn ? '登录' : '保存'}}</button>
      </view>
    </view>
  </view>
</view>